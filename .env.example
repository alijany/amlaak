# Platform Environment Configuration
# Copy this file to .env and update with your values

###################
# Core API Configuration
###################
NODE_ENV=production
PORT=4000
APP_NAME=App
APP_VERSION=1.0.0

###################
# Database Configuration
###################
POSTGRES_USER='postgres'
PGUSER='postgres'
POSTGRES_DB='app'
POSTGRES_PASSWORD='pass123'
DB_HOST='db'
DB_PORT='5432'
DB_NAME='app'


###################
# Redis Configuration
###################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

###################
# JWT Configuration
###################
JWT_SECRET=your_secure_jwt_secret_here_minimum_32_characters
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here_minimum_32_characters
JWT_REFRESH_EXPIRATION=30d

###################
# OTP Configuration
###################
OTP_EXPIRATION=300
OTP_LENGTH=6

###################
# SMS Configuration (Kavenegar)
###################
KAVENEGAR_API_KEY=your_kavenegar_api_key_here
KAVENEGAR_SENDER=your_sender_number
KAVENEGAR_TEMPLATE=your_template_name

###################
# S3 Storage Configuration (MinIO)
###################
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=your_minio_access_key
S3_SECRET_KEY=your_minio_secret_key
S3_BUCKET_NAME='app-dev'
S3_BUCKET=app
S3_REGION=us-east-1

###################
# Payment Gateway Configuration
###################

# Zibal Payment Gateway
ZIBAL_MERCHANT=ZIBAL_MERCHANT_ID
ZIBAL_CALLBACK_URL=https://app.ir/api/v1/payment/zibal-callback
ZIBAL_FRONTEND_CALLBACK_URL=https://app.ir/dashboard/payments

# Jibit Payment Gateway
JIBIT_API_KEY=your_jibit_api_key
JIBIT_SECRET_KEY=your_jibit_secret_key
JIBIT_CALLBACK_URL=https://app.ir/api/v1/payment/jibit-callback

###################
# PWA Frontend Configuration
###################
NEXT_PUBLIC_API_URL=https://app.ir/api/v1

# Microsoft Clarity Analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=ud8qbqx1oy

# Enable mock payments (set to 'true' for development/testing only)
# NEXT_PUBLIC_ENABLE_MOCK_PAYMENTS=false

###################
# Postgres Backup Configuration
###################
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7
