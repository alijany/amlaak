# Navamelk Platform Environment Configuration
# Copy this file to .env and update with your values

###################
# Core API Configuration
###################
NODE_ENV=production
PORT=4000
PROJECT_NAME=App
APP_VERSION=1.0.0

# Admin bootstrap (optional)
# If set, core-api will ensure a user with this phone exists and has the `admin` role on startup.
# Use E.164 format if possible (e.g. +989123456789).
ADMIN_PHONE=''

###################
# Database Configuration
###################
POSTGRES_USER='postgres'
POSTGRES_PASSWORD='pass123'
POSTGRES_DB='app'
POSTGRES_PORT='5432'
DB_HOST='db'

###################
# Redis Configuration
###################
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

###################
# JWT Configuration
###################
JWT_SECRET=your_secure_jwt_secret_here_minimum_32_characters
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_secure_jwt_refresh_secret_here_minimum_32_characters
JWT_REFRESH_EXPIRATION=30d

###################
# OTP Configuration
###################
OTP_EXPIRATION=300
OTP_LENGTH=4

###################
# SMS Configuration
###################
ASANAK_API='https://sms.asanak.ir/webservice/v2rest/sendsms'
ASANAK_API_USER='asanak_user_name'
ASANAK_API_PASS='asanak_api_password'
ASANAK_API_SOURCE='asanak_phone_password'

###################
# S3 Storage Configuration (MinIO)
###################
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=your_minio_access_key
S3_SECRET_KEY=your_minio_secret_key
S3_BUCKET_NAME='app-dev'
S3_BUCKET=app
S3_REGION=us-east-1

###################
# Crawler Configuration
###################
# Master switch for the crawler subsystem (informational; the Mock target works regardless).
CRAWLER_ENABLED=true

# Camoufox stealth-browser sidecar (https://github.com/jo-inc/camofox-browser).
# Only the real-browser crawlers (e.g. Divar) need it; the Mock target runs
# without a browser. Defaults to the docker-compose service host; use
# http://localhost:9377 for a manually-run sidecar.
CAMOFOX_BASE_URL=http://camofox:9377
CAMOFOX_API_KEY=

# Optional proxying, consumed by the Camoufox sidecar itself.
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_STRATEGY=

# Politeness: cap how many crawl jobs the queue runs per window (across targets).
CRAWL_QUEUE_MAX=5
CRAWL_QUEUE_DURATION_MS=10000

# Ad image storage: download source images and upload them to S3 (set to 'false'
# to keep the original source URLs instead). Bounded per ad with a timeout.
CRAWLER_STORE_IMAGES=true
CRAWLER_IMAGE_MAX_PER_AD=8
CRAWLER_IMAGE_TIMEOUT_MS=15000
CRAWLER_IMAGE_MAX_BYTES=8000000

###################
# Telegram / Publishing Configuration
###################
# Optional. When a listing is approved in the dashboard it is posted to this
# Telegram channel and made visible on the public site. If unset, approval still
# works and the public site still shows the listing — only the Telegram post is skipped.
# The bot must be an admin of the channel. TELEGRAM_CHANNEL_ID may be a numeric
# id (e.g. -1001234567890) or a public @username.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
# Optional. A single operator-managed Telegram chat that receives admin alerts
# for important events (new agency pending confirmation, a crawl finishing with
# new ads to review, a new agency listing awaiting approval). Same id format as
# TELEGRAM_CHANNEL_ID. The bot must be a member/admin of the chat. If unset,
# admin alerts are skipped — nothing else is affected.
TELEGRAM_ADMIN_CHAT_ID=
# Public base URL used to build listing links in Telegram posts (no trailing slash).
DOMAIN=https://app.ir
# Optional SOCKS proxy for reaching api.telegram.org (e.g. where Telegram is
# blocked). When set, all Bot API calls are routed through it; leave empty to
# connect directly. Form: socks5://[user:pass@]host:port — prefer socks5h://
# so DNS is resolved through the proxy. Point this at the xray sidecar in the
# devcontainer: socks5h://xray:1080
TELEGRAM_PROXY_URL=

###################
# Payment Gateway Configuration
###################

# Zibal Payment Gateway
ZIBAL_MERCHANT=your_zibal_merchant_id
ZIBAL_CALLBACK_URL=http://app.ir/api/v1/payment/zibal-callback
ZIBAL_FRONTEND_CALLBACK_URL=http://app.ir/dashboard/transaction/zibal

###################
# PWA Frontend Configuration
###################
NEXT_PUBLIC_API_URL=https://app.ir/api/v1

# Microsoft Clarity Analytics
NEXT_PUBLIC_CLARITY_PROJECT_ID=clarity_project_id
