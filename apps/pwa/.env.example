# Environment Configuration for the PWA

# Backend API Configuration
# URL for the Core API service
# Default: http://localhost:4000/api/v1 for local development
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Development Configuration
# Set to 'development' for local development
NODE_ENV=development

# Production Configuration (uncomment and set for production)
# NEXT_PUBLIC_API_URL=https://app.ir/api/v1
# NODE_ENV=production

# Microsoft Clarity Analytics Configuration
# Project ID from https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_PROJECT_ID=clarity_project_id
