CAMOFOX_API_KEY=1d5f2950a34f2d0dc99efde9f4277fe15a8ab31299b651eb4efb218b7e8680d3

###################
# Xray proxy sidecar (for reaching api.telegram.org where it is blocked)
###################
# The backend connects to this via TELEGRAM_PROXY_URL=socks5h://xray:1080
# (SOCKS5 inbound; an HTTP inbound is also exposed on :1081). Configure the
# remote VLESS server directly in .devcontainer/xray-config.json.
TELEGRAM_PROXY_URL=socks5h://xray:1080