{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "port": 1080,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    },
    {
      "tag": "http-in",
      "listen": "0.0.0.0",
      "port": 1081,
      "protocol": "http",
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "address": "fortnite.saman.my",
        "encryption": "none",
        "flow": "",
        "id": "21089d6e-08d4-4b55-8def-89836808e2f2",
        "port": 443
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "sockopt": {
          "domainStrategy": "UseIPv4v6"
        },
        "tlsSettings": {
          "alpn": [
            "h2"
          ],
          "fingerprint": "ios",
          "serverName": "fortnite.saman.my"
        },
        "xhttpSettings": {
          "extra": {
            "scMaxEachPostBytes": "1000000",
            "scMinPostsIntervalMs": "30",
            "xPaddingBytes": "10-50"
          },
          "host": "fortnite.saman.my",
          "mode": "packet-up",
          "path": "/account"
        }
      },
      "tag": "proxy"
    },
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "domain": [
          "domain:telegram.org",
          "domain:t.me",
          "geosite:telegram"
        ],
        "outboundTag": "proxy"
      },
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "direct"
      },
      {
        "type": "field",
        "network": "tcp,udp",
        "outboundTag": "proxy"
      }
    ]
  }
}
